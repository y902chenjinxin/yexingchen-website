{
  "name": "yexingchen-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .vue,.js,.jsx,.ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node test_site.cjs"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "element-plus": "^2.7.2",
    "pinia": "^2.1.7",
    "three": "^0.184.0",
    "vue": "^3.4.27",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.6.0",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "playwright": "^1.60.0",
    "vite": "^5.2.11",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{vue,js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
