# 后端环境变量配置示例
# 复制此文件为 .env 并填入真实值

# 数据库
DATABASE_URL=sqlite:///./yexingchen.db

# JWT（请修改为随机字符串）
SECRET_KEY=your-random-secret-key-here-change-this

# QQ邮箱授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=1678069299@qq.com
SMTP_PASSWORD=your-qq-email-auth-code

# 腾讯COS（请填入真实密钥）
COS_SECRET_ID=your-tencent-cos-secret-id
COS_SECRET_KEY=your-tencent-cos-secret-key
COS_BUCKET=yexingfiles-1409757734
COS_REGION=ap-guangzhou

# 环境
ENV=development